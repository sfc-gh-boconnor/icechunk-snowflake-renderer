-- ── Grants to the service identity role ───────────────────────────────────────
GRANT USAGE ON SERVICE    ${DB}.${SCHEMA}.ICECHUNK_SERVICE             TO ROLE ${ROLE};
GRANT USAGE ON SERVICE    ${DB}.${SCHEMA}.ICECHUNK_ACCELERATOR_SERVICE TO ROLE ${ROLE};
GRANT SERVICE ROLE ${DB}.${SCHEMA}.ICECHUNK_SERVICE!ALL_ENDPOINTS_USAGE
    TO ROLE ${ROLE};
GRANT SERVICE ROLE ${DB}.${SCHEMA}.ICECHUNK_ACCELERATOR_SERVICE!ALL_ENDPOINTS_USAGE
    TO ROLE ${ROLE};

GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_HEALTH()                                                  TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_META()                                                    TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SEED()                                                    TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SLICE(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR)            TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SLICE_H3(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR,NUMBER)  TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_CLOUD_AT_LEVEL(FLOAT,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR)    TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_CLOUD_AT_LEVEL_H3(FLOAT,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR,NUMBER) TO ROLE ${ROLE};

GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_META_UK()                                                                          TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SEED_UK()                                                                          TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SEED_UK_VARS(VARCHAR)                                                              TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SLICE_UK(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR)                                  TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SLICE_H3_UK(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR,NUMBER)                        TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_LEVEL_SLICE_UK(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR)                      TO ROLE ${ROLE};
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_LEVEL_SLICE_H3_UK(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR,NUMBER)            TO ROLE ${ROLE};

-- ── Grants to SYSADMIN (owner of the agent tool procedures created in 05) ─────
-- 05_create_agent.sql does USE ROLE SYSADMIN, so TOOL_WEATHER_* procedures run
-- EXECUTE AS OWNER = SYSADMIN. The owner therefore needs USAGE on the backend
-- service + its endpoint + the functions the tools call (META, SLICE_H3).
GRANT USAGE ON SERVICE ${DB}.${SCHEMA}.ICECHUNK_SERVICE TO ROLE SYSADMIN;
GRANT SERVICE ROLE ${DB}.${SCHEMA}.ICECHUNK_SERVICE!ALL_ENDPOINTS_USAGE TO ROLE SYSADMIN;
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_META()                                                    TO ROLE SYSADMIN;
GRANT USAGE ON FUNCTION ${DB}.${SCHEMA}.ICECHUNK_SLICE_H3(VARCHAR,FLOAT,FLOAT,FLOAT,FLOAT,VARCHAR,NUMBER)  TO ROLE SYSADMIN;

SELECT 'Functions + grants applied for ${DB}' AS status;
