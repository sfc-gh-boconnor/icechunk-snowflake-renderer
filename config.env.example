# =============================================================================
# IceChunk Weather Accelerator — deployment configuration
# =============================================================================
# Copy this file to `config.env` and fill in your own values.
# `config.env` is gitignored and must NEVER be committed (it holds AWS creds).
#
#   cp config.env.example config.env
#   # edit DEPLOY_PREFIX / S3_BUCKET / AWS_REGION / ICECHUNK_CONNECTION below
#   bash provision_aws.sh    # creates the bucket (if missing) + a per-prefix IAM
#                            # user scoped to s3://<bucket>/<prefix>/* and writes
#                            # the AWS key/secret below for you
#   bash setup.sh            # one-time Snowflake setup (prefixed DB/WH/pool/EAIs
#                            # + service functions + AWS secrets)
#   bash build.sh --bump patch   # build + push the two SPCS images
#   bash deploy.sh           # deploy the SPCS services + print the app URL
#
# SHARED-ACCOUNT SAFE. Unlike a per-account deployment, the target may be a
# SHARED Snowflake account (e.g. an SE builders workshop). DEPLOY_PREFIX
# therefore namespaces BOTH:
#   - S3 objects:  s3://<S3_BUCKET>/<DEPLOY_PREFIX>/met_office_global/
#                  s3://<S3_BUCKET>/<DEPLOY_PREFIX>/met_office_uk_2km/
#   - Snowflake objects (uppercased suffix), so nothing collides with other
#     builders on the same account:
#       DB     ICECHUNK_DB_<PREFIX>     WH    ICECHUNK_WH_<PREFIX>
#       POOL   ICECHUNK_POOL_<PREFIX>   ROLE  ICECHUNK_ROLE_<PREFIX>
#       USER   ICECHUNK_<PREFIX>        EAIs  ICECHUNK_S3_EAI_<PREFIX>, ...
# Pick a unique DEPLOY_PREFIX (lowercase letters/digits/underscores: ^[a-z0-9_]+$).
# =============================================================================

# Snowflake CLI connection name (from ~/.snowflake/connections.toml).
# The credential must allow multi-role access including ACCOUNTADMIN (needed to
# create the compute pool, EAIs, and image repository).
ICECHUNK_CONNECTION="internal-marketplace"

# -----------------------------------------------------------------------------
# Unique deployment prefix — namespaces S3 paths AND Snowflake object names.
# MUST be lowercase letters, digits and underscores only:  ^[a-z0-9_]+$
# Pick something unique to you, e.g. your team / region / account name.
# -----------------------------------------------------------------------------
DEPLOY_PREFIX="my_team"

# -----------------------------------------------------------------------------
# S3 bucket (may be shared across deployers; isolated by DEPLOY_PREFIX + a
# per-prefix IAM user scoped to s3://<S3_BUCKET>/<DEPLOY_PREFIX>/*).
# -----------------------------------------------------------------------------
# IMPORTANT: use a bucket in the SAME region as your Snowflake account
# (SELECT CURRENT_REGION();). SFSEHOL accounts are us-west-2.
S3_BUCKET="icechunk-ro"
AWS_REGION="us-west-2"

# AWS access key with read/write on s3://<S3_BUCKET>/<DEPLOY_PREFIX>/* .
# AUTO-FILLED by `provision_aws.sh` (creates the per-prefix IAM user + key).
AWS_ACCESS_KEY_ID="TO_BE_FILLED_BY_provision_aws.sh"
AWS_SECRET_ACCESS_KEY="TO_BE_FILLED_BY_provision_aws.sh"
